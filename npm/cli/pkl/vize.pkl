/// Shared schema for `vize.config.pkl`.
///
/// Example:
/// amends "node_modules/vize/pkl/vize.pkl"
///
/// compiler {
///   sourceMap = true
/// }
module vize.Config

typealias CompilerMode = "module" | "function"
typealias TemplateSyntax = "standard" | "strict" | "quirks"
typealias JsxMode = "vdom" | "vapor"
typealias ScriptExt = "ts" | "js"
typealias RuleSeverity = "off" | "warn" | "error"
typealias LintPreset = "happy-path" | "opinionated" | "essential" | "incremental" | "ecosystem" | "nuxt"
typealias TrailingComma = "all" | "none" | "es5"
typealias FilterPattern = String | Listing<String>
typealias GlobalTypeValue = String | GlobalTypeDeclaration
typealias ConfigExtends = String | Listing<String>

class CompilerConfig {
  mode: CompilerMode? = null
  vapor: Boolean? = null
  jsxMode: JsxMode? = null
  customRenderer: Boolean? = null
  ssr: Boolean? = null
  templateSyntax: TemplateSyntax? = null
  sourceMap: Boolean? = null
  prefixIdentifiers: Boolean? = null
  hoistStatic: Boolean? = null
  cacheHandlers: Boolean? = null
  isTs: Boolean? = null
  scriptExt: ScriptExt? = null
  runtimeModuleName: String? = null
  runtimeGlobalName: String? = null
}

class VitePluginConfig {
  include: FilterPattern? = null
  exclude: FilterPattern? = null
  scanPatterns: Listing<String>? = null
  precompileBatchSize: Int? = null
  ignorePatterns: Listing<String>? = null
}

class RestrictedGlobal {
  name: String
  message: String? = null
}

class RestrictedMember {
  object: String
  property: String
  message: String? = null
}

class NoRestrictedGlobalsOptions {
  globals: Listing<RestrictedGlobal>? = null
}

class NoRestrictedMembersOptions {
  members: Listing<RestrictedMember>? = null
}

class LintRuleOptions {
  `script/no-restricted-globals`: NoRestrictedGlobalsOptions? = null
  `script/no-restricted-members`: NoRestrictedMembersOptions? = null
}

class LinterConfig {
  enabled: Boolean? = null
  preset: LintPreset? = null
  typeAware: Boolean? = null
  rules: Mapping<String, RuleSeverity>? = null
  ruleOptions: LintRuleOptions? = null
  categories: Mapping<String, RuleSeverity>? = null
}

class TypeCheckerConfig {
  enabled: Boolean? = null
  strict: Boolean? = null
  checkProps: Boolean? = null
  checkEmits: Boolean? = null
  checkTemplateBindings: Boolean? = null
  checkReactivity: Boolean? = null
  checkSetupContext: Boolean? = null
  checkInvalidExports: Boolean? = null
  checkFallthroughAttrs: Boolean? = null
  legacyVue2: Boolean? = null
  jsxTypecheck: Boolean? = null
  tsconfig: String? = null
  corsaPath: String? = null
  tsgoPath: String? = null
  globalsFile: String? = null
  servers: Int? = null
}

class FormatterConfig {
  printWidth: Int? = null
  tabWidth: Int? = null
  useTabs: Boolean? = null
  semi: Boolean? = null
  singleQuote: Boolean? = null
  trailingComma: TrailingComma? = null
}

class LspConfig {
  enabled: Boolean? = null
  lint: Boolean? = null
  /// Deprecated: use `lint`.
  diagnostics: Boolean? = null
  typecheck: Boolean? = null
  editor: Boolean? = null
  ecosystem: Boolean? = null
  legacyVue2: Boolean? = null
  completion: Boolean? = null
  hover: Boolean? = null
  definition: Boolean? = null
  references: Boolean? = null
  documentSymbols: Boolean? = null
  workspaceSymbols: Boolean? = null
  formatting: Boolean? = null
  codeActions: Boolean? = null
  rename: Boolean? = null
  codeLens: Boolean? = null
  semanticTokens: Boolean? = null
  documentLinks: Boolean? = null
  foldingRanges: Boolean? = null
  inlayHints: Boolean? = null
  fileRename: Boolean? = null
  corsa: Boolean? = null
  /// Deprecated: use `corsa`.
  tsgo: Boolean? = null
}

class MuseaViewport {
  width: Number
  height: Number
  name: String? = null
}

class MuseaVrtConfig {
  threshold: Number? = null
  outDir: String? = null
  viewports: Listing<MuseaViewport>? = null
}

class MuseaA11yConfig {
  enabled: Boolean? = null
  rules: Mapping<String, Boolean>? = null
}

class MuseaAutogenConfig {
  enabled: Boolean? = null
  maxVariants: Int? = null
}

class MuseaConfig {
  include: Listing<String>? = null
  exclude: Listing<String>? = null
  basePath: String? = null
  storybookCompat: Boolean? = null
  inlineArt: Boolean? = null
  vrt: MuseaVrtConfig?
  a11y: MuseaA11yConfig?
  autogen: MuseaAutogenConfig?
}

class GlobalTypeDeclaration {
  type: String
  defaultValue: String? = null
}

class ConfigEntry {
  name: String? = null
  basePath: String? = null
  files: Listing<String>? = null
  ignores: Listing<String>? = null
  `extends`: ConfigExtends? = null
  compiler: CompilerConfig?
  vite: VitePluginConfig?
  linter: LinterConfig?
  typeChecker: TypeCheckerConfig?
  formatter: FormatterConfig?
  languageServer: LspConfig?
  /// Deprecated: use `languageServer`.
  lsp: LspConfig?
  musea: MuseaConfig?
  globalTypes: Mapping<String, GlobalTypeValue>? = null
}

name: String? = null
basePath: String? = null
files: Listing<String>? = null
ignores: Listing<String>? = null
`extends`: ConfigExtends? = null
compiler: CompilerConfig?
vite: VitePluginConfig?
linter: LinterConfig?
typeChecker: TypeCheckerConfig?
formatter: FormatterConfig?
languageServer: LspConfig?
/// Deprecated: use `languageServer`.
lsp: LspConfig?
musea: MuseaConfig?
globalTypes: Mapping<String, GlobalTypeValue>? = null
entries: Listing<ConfigEntry>? = null
