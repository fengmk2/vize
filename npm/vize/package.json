{
  "name": "vize",
  "version": "0.199.0",
  "description": "Vize - High-performance Vue.js toolchain in Rust",
  "keywords": [
    "cli",
    "compiler",
    "formatter",
    "linter",
    "rust",
    "vize",
    "vue"
  ],
  "homepage": "https://github.com/ubugeeei-prod/vize",
  "bugs": {
    "url": "https://github.com/ubugeeei-prod/vize/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei-prod/vize",
    "directory": "npm/vize"
  },
  "bin": {
    "vize": "bin/vize"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "schemas",
    "pkl"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    },
    "./schemas/vize.config.schema.json": "./schemas/vize.config.schema.json",
    "./pkl/vize.pkl": "./pkl/vize.pkl"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp run --workspace-root generate:rule-types && vp pack",
    "check": "vp check src vite.config.ts",
    "check:fix": "vp check --fix src vite.config.ts",
    "fmt": "vp fmt --write src vite.config.ts",
    "generate:rule-types": "vp run --workspace-root generate:rule-types"
  },
  "dependencies": {
    "@vizejs/native": "workspace:*",
    "oxc-transform": "catalog:oxc",
    "vue": "catalog:vue-stable"
  },
  "devDependencies": {
    "@pkl-community/pkl": "catalog:repo-tooling",
    "@tsdown/css": "catalog:content",
    "@types/node": "catalog:typescript",
    "tsdown": "catalog:vite-stack",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite-stack",
    "vite-plus": "catalog:vite-stack"
  },
  "peerDependencies": {
    "@pkl-community/pkl": "catalog:repo-tooling"
  },
  "peerDependenciesMeta": {
    "@pkl-community/pkl": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@typescript/native-preview": "catalog:typescript"
  },
  "engines": {
    "node": ">=22"
  }
}
