name: defineEmits with dollar emit usage keeps emit param
options: sfc
--- INPUT ---
<script setup>
defineEmits(['change'])
const count = 1
</script>

<template>
  <div @click="$emit('change')">{{ count }}</div>
</template>
--- OUTPUT ---
