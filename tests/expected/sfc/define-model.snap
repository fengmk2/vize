name: defineModel multiple models
options: sfc
--- INPUT ---
<script setup>
const modelValue = defineModel({ required: true })
const c = defineModel('count')
const toString = defineModel('toString', { type: Function })
</script>

<template>
  <div>{{ modelValue }} {{ c }} {{ toString }}</div>
</template>
