// SFC tests: reactive props destructure default codegen + useTemplateRef binding.
// Based on Vue.js core compiler-sfc/__tests__/compileScript/definePropsDestructure.spec.ts

amends "SfcFixture.pkl"

mode = "sfc"

cases {
  new {
    name = "destructure defaults in source order"
    input = """
    <script setup>
    const { count = 1, label = 'x' } = defineProps(['count', 'label'])
    </script>

    <template>
      <div>{{ count }} {{ label }}</div>
    </template>

    """
  }
  new {
    name = "destructure default kinds factory and skip"
    input = """
    <script setup>
    const { a = 1, b = [1, 2], c = () => {}, d = obj } = defineProps(['a', 'b', 'c', 'd'])
    </script>

    <template>
      <div>{{ a }} {{ b }} {{ c }} {{ d }}</div>
    </template>

    """
  }
  new {
    name = "destructure object default is factory wrapped"
    input = """
    <script setup>
    const { config = { open: true } } = defineProps(['config'])
    </script>

    <template>
      <div>{{ config }}</div>
    </template>

    """
  }
  new {
    name = "useTemplateRef binding is a setup ref"
    input = """
    <script setup>
    import { useTemplateRef, onMounted } from 'vue'
    const el = useTemplateRef('myEl')
    onMounted(() => {
      console.log(el.value)
    })
    </script>

    <template>
      <div>{{ el }}</div>
    </template>

    """
  }
}
